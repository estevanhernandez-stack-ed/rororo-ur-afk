<Application x:Class="Labs626.UrAfk.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             ShutdownMode="OnExplicitShutdown">
    <Application.Resources>
        <ResourceDictionary>
            <BooleanToVisibilityConverter x:Key="BoolToVis"/>

            <!-- 626 Labs brand tokens, host slot names (theming-sync playbook:
                 docs/theming-sync.md). HostThemeService replaces these instances
                 live from RoRoRo's active theme — consume via DynamicResource.
                 AmberBrush themes from the host's row_expired_accent slot. -->
            <SolidColorBrush x:Key="BgBrush" Color="#0F1F31"/>
            <SolidColorBrush x:Key="CyanBrush" Color="#17D4FA"/>
            <SolidColorBrush x:Key="MagentaBrush" Color="#F22F89"/>
            <SolidColorBrush x:Key="WhiteBrush" Color="#FFFFFF"/>
            <SolidColorBrush x:Key="MutedTextBrush" Color="#9AA8B8"/>
            <SolidColorBrush x:Key="DividerBrush" Color="#1F3149"/>
            <SolidColorBrush x:Key="RowBgBrush" Color="#15263A"/>
            <SolidColorBrush x:Key="RowHoverBrush" Color="#1B3046"/>
            <SolidColorBrush x:Key="AmberBrush" Color="#F1B232"/>
        </ResourceDictionary>
    </Application.Resources>
</Application>
