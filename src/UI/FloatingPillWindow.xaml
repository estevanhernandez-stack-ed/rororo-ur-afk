<Window x:Class="Labs626.UrAfk.UI.FloatingPillWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="RoRoRo Ur AFK"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        Topmost="True"
        ShowInTaskbar="False"
        ResizeMode="NoResize"
        SizeToContent="WidthAndHeight"
        Visibility="{Binding Visible, Converter={StaticResource BoolToVis}}">
    <Window.Resources>
        <!-- Tiny flat round buttons for the hover-revealed quick controls. -->
        <Style x:Key="PillButton" TargetType="Button">
            <Setter Property="Width" Value="22"/>
            <Setter Property="Height" Value="22"/>
            <Setter Property="Foreground" Value="{DynamicResource MutedTextBrush}"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Focusable" Value="False"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Root" Background="Transparent" CornerRadius="11">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="{DynamicResource RowHoverBrush}"/>
                                <Setter Property="Foreground" Value="{DynamicResource WhiteBrush}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>
    <Border Background="{DynamicResource BgBrush}"
            BorderBrush="{DynamicResource DividerBrush}"
            BorderThickness="1"
            CornerRadius="16" Padding="12,7">
        <Border.Effect>
            <DropShadowEffect BlurRadius="14" ShadowDepth="2" Opacity="0.45"/>
        </Border.Effect>
        <StackPanel Orientation="Horizontal">
            <!-- Status dot — themed per state; pulses through the pre-grab countdown. -->
            <Border Width="10" Height="10" CornerRadius="5" VerticalAlignment="Center">
                <Border.Style>
                    <Style TargetType="Border">
                        <Setter Property="Background" Value="{DynamicResource MutedTextBrush}"/>
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding Kind}" Value="Watching">
                                <Setter Property="Background" Value="{DynamicResource CyanBrush}"/>
                            </DataTrigger>
                            <DataTrigger Binding="{Binding Kind}" Value="Kept">
                                <Setter Property="Background" Value="{DynamicResource CyanBrush}"/>
                            </DataTrigger>
                            <DataTrigger Binding="{Binding Kind}" Value="Grabbing">
                                <Setter Property="Background" Value="{DynamicResource MagentaBrush}"/>
                            </DataTrigger>
                            <DataTrigger Binding="{Binding Kind}" Value="ConsentRevoked">
                                <Setter Property="Background" Value="{DynamicResource AmberBrush}"/>
                            </DataTrigger>
                            <DataTrigger Binding="{Binding Kind}" Value="PreGrab">
                                <Setter Property="Background" Value="{DynamicResource AmberBrush}"/>
                                <DataTrigger.EnterActions>
                                    <BeginStoryboard x:Name="PillPulse">
                                        <Storyboard RepeatBehavior="Forever" AutoReverse="True">
                                            <DoubleAnimation Storyboard.TargetProperty="Opacity"
                                                             From="1.0" To="0.25" Duration="0:0:0.45"/>
                                        </Storyboard>
                                    </BeginStoryboard>
                                </DataTrigger.EnterActions>
                                <DataTrigger.ExitActions>
                                    <StopStoryboard BeginStoryboardName="PillPulse"/>
                                </DataTrigger.ExitActions>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Border.Style>
            </Border>
            <TextBlock Text="{Binding Text}" Foreground="{DynamicResource WhiteBrush}" Margin="8,0,0,0"
                       VerticalAlignment="Center" FontSize="12" FontFamily="{StaticResource BodyFont}"/>

            <!-- Quick controls — revealed on hover so the pill stays a quiet
                 indicator until you reach for it. -->
            <StackPanel Orientation="Horizontal" Margin="8,0,0,0">
                <StackPanel.Style>
                    <Style TargetType="StackPanel">
                        <Setter Property="Visibility" Value="Collapsed"/>
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding IsMouseOver, RelativeSource={RelativeSource AncestorType=Window}}" Value="True">
                                <Setter Property="Visibility" Value="Visible"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </StackPanel.Style>
                <Border Width="1" Background="{DynamicResource DividerBrush}" Margin="0,2,6,2"/>
                <Button Command="{Binding ToggleMasterCommand}" ToolTip="Keep-active on/off">
                    <Button.Style>
                        <Style TargetType="Button" BasedOn="{StaticResource PillButton}">
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding MasterEnabled}" Value="True">
                                    <Setter Property="Foreground" Value="{DynamicResource CyanBrush}"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Button.Style>
                    <TextBlock Text="⏻" FontWeight="Bold"/>
                </Button>
                <Button Style="{StaticResource PillButton}"
                        Command="{Binding SkipCommand}"
                        ToolTip="Skip the next grab (F8)">
                    <TextBlock Text="⏭"/>
                </Button>
                <Button Style="{StaticResource PillButton}"
                        Command="{Binding OpenMainCommand}"
                        ToolTip="Open Ur AFK">
                    <TextBlock Text="⤢"/>
                </Button>
            </StackPanel>
        </StackPanel>
    </Border>
</Window>
