<Window x:Class="Labs626.UrAfk.UI.FloatingPillWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="RoRoRo Ur AFK"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        Topmost="True"
        ShowInTaskbar="False"
        ResizeMode="NoResize"
        SizeToContent="WidthAndHeight"
        Visibility="{Binding Visible, Converter={StaticResource BoolToVis}}">
    <Border Background="{StaticResource NavyFieldBrush}" CornerRadius="16" Padding="12,7">
        <Border.Effect>
            <DropShadowEffect BlurRadius="14" ShadowDepth="2" Opacity="0.45"/>
        </Border.Effect>
        <StackPanel Orientation="Horizontal">
            <Border Width="10" Height="10" CornerRadius="5" VerticalAlignment="Center"
                    Background="{Binding Kind, Converter={StaticResource PillBrush}}"/>
            <TextBlock Text="{Binding Text}" Foreground="White" Margin="8,0,0,0"
                       VerticalAlignment="Center" FontSize="12" FontFamily="Segoe UI"/>
        </StackPanel>
    </Border>
</Window>
