<Window x:Class="Labs626.UrAfk.UI.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:sys="clr-namespace:System;assembly=mscorlib"
        xmlns:core="clr-namespace:Labs626.UrAfk.Core"
        Title="RoRoRo Ur AFK" Width="420" Height="640"
        MinWidth="380" MinHeight="500"
        Icon="pack://application:,,,/icon.png"
        Background="{DynamicResource BgBrush}"
        FontFamily="{StaticResource BodyFont}"
        WindowStyle="None"
        AllowsTransparency="True"
        ResizeMode="CanResizeWithGrip"
        WindowStartupLocation="CenterScreen">
    <Window.Resources>
        <ObjectDataProvider x:Key="PillModeValues" MethodName="GetValues" ObjectType="{x:Type sys:Enum}">
            <ObjectDataProvider.MethodParameters>
                <x:Type TypeName="core:PillMode"/>
            </ObjectDataProvider.MethodParameters>
        </ObjectDataProvider>
        <ObjectDataProvider x:Key="PillCornerValues" MethodName="GetValues" ObjectType="{x:Type sys:Enum}">
            <ObjectDataProvider.MethodParameters>
                <x:Type TypeName="core:PillCorner"/>
            </ObjectDataProvider.MethodParameters>
        </ObjectDataProvider>
    </Window.Resources>

    <Border Background="{DynamicResource BgBrush}"
            BorderBrush="{DynamicResource DividerBrush}"
            BorderThickness="1"
            CornerRadius="10">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/> <!-- title bar -->
                <RowDefinition Height="*"/>    <!-- content -->
            </Grid.RowDefinitions>

            <!-- Custom title bar — family chrome. -->
            <Grid Grid.Row="0"
                  Background="Transparent"
                  Height="36"
                  MouseLeftButtonDown="OnTitleBarDrag">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0" Orientation="Horizontal" Margin="14,0,0,0" VerticalAlignment="Center">
                    <Image Source="pack://application:,,,/icon.png" Width="16" Height="16" Margin="0,0,8,0"/>
                    <TextBlock Text="RORORO UR AFK"
                               FontFamily="{StaticResource MonoFont}"
                               FontSize="9"
                               Foreground="{DynamicResource CyanBrush}"
                               VerticalAlignment="Center"/>
                </StackPanel>
                <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Stretch">
                    <Button Content="—" Width="38"
                            Background="Transparent" BorderThickness="0"
                            Foreground="{DynamicResource MutedTextBrush}" FontSize="14"
                            Click="OnMinimizeClicked"/>
                    <Button Content="✕" Width="38"
                            Background="Transparent" BorderThickness="0"
                            Foreground="{DynamicResource MutedTextBrush}" FontSize="12"
                            ToolTip="Close to tray — the pill and keep-active loop stay running"
                            Click="OnCloseClicked"/>
                </StackPanel>
            </Grid>

            <!-- Content -->
            <Grid Grid.Row="1" Margin="16,4,16,14">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/> <!-- 0: status banner -->
                    <RowDefinition Height="Auto"/> <!-- 1: master toggle + threshold -->
                    <RowDefinition Height="*"/>    <!-- 2: account rows -->
                    <RowDefinition Height="Auto"/> <!-- 3: notifications -->
                    <RowDefinition Height="Auto"/> <!-- 4: footer -->
                </Grid.RowDefinitions>

                <!-- Status banner — dot + state text; border escalates with the
                     pill state and the dot pulses during the pre-grab countdown. -->
                <Border Grid.Row="0"
                        Background="{DynamicResource RowBgBrush}"
                        BorderThickness="1"
                        CornerRadius="6"
                        Padding="12,9"
                        Margin="0,0,0,12">
                    <Border.Style>
                        <Style TargetType="Border">
                            <Setter Property="BorderBrush" Value="{DynamicResource DividerBrush}"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding Pill.Kind}" Value="PreGrab">
                                    <Setter Property="BorderBrush" Value="{DynamicResource AmberBrush}"/>
                                </DataTrigger>
                                <DataTrigger Binding="{Binding Pill.Kind}" Value="Grabbing">
                                    <Setter Property="BorderBrush" Value="{DynamicResource MagentaBrush}"/>
                                </DataTrigger>
                                <DataTrigger Binding="{Binding Pill.Kind}" Value="Kept">
                                    <Setter Property="BorderBrush" Value="{DynamicResource CyanBrush}"/>
                                </DataTrigger>
                                <DataTrigger Binding="{Binding Pill.Kind}" Value="Disconnected">
                                    <Setter Property="BorderBrush" Value="{DynamicResource MagentaBrush}"/>
                                </DataTrigger>
                                <DataTrigger Binding="{Binding Pill.Kind}" Value="ConsentRevoked">
                                    <Setter Property="BorderBrush" Value="{DynamicResource AmberBrush}"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Border.Style>
                    <StackPanel Orientation="Horizontal">
                        <Border Width="10" Height="10" CornerRadius="5" VerticalAlignment="Center">
                            <Border.Style>
                                <Style TargetType="Border">
                                    <Setter Property="Background" Value="{DynamicResource MutedTextBrush}"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding Pill.Kind}" Value="Watching">
                                            <Setter Property="Background" Value="{DynamicResource CyanBrush}"/>
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding Pill.Kind}" Value="Kept">
                                            <Setter Property="Background" Value="{DynamicResource CyanBrush}"/>
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding Pill.Kind}" Value="Grabbing">
                                            <Setter Property="Background" Value="{DynamicResource MagentaBrush}"/>
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding Pill.Kind}" Value="ConsentRevoked">
                                            <Setter Property="Background" Value="{DynamicResource AmberBrush}"/>
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding Pill.Kind}" Value="PreGrab">
                                            <Setter Property="Background" Value="{DynamicResource AmberBrush}"/>
                                            <DataTrigger.EnterActions>
                                                <BeginStoryboard x:Name="BannerPulse">
                                                    <Storyboard RepeatBehavior="Forever" AutoReverse="True">
                                                        <DoubleAnimation Storyboard.TargetProperty="Opacity"
                                                                         From="1.0" To="0.25" Duration="0:0:0.45"/>
                                                    </Storyboard>
                                                </BeginStoryboard>
                                            </DataTrigger.EnterActions>
                                            <DataTrigger.ExitActions>
                                                <StopStoryboard BeginStoryboardName="BannerPulse"/>
                                            </DataTrigger.ExitActions>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Border.Style>
                        </Border>
                        <TextBlock Text="{Binding Pill.Text}"
                                   Foreground="{DynamicResource WhiteBrush}"
                                   FontWeight="SemiBold"
                                   Margin="10,0,0,0"
                                   VerticalAlignment="Center"
                                   TextTrimming="CharacterEllipsis"/>
                    </StackPanel>
                </Border>

                <!-- Master toggle + threshold -->
                <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,0,0,12">
                    <ToggleButton Content="Keep-active" IsChecked="{Binding MasterEnabled}" Margin="0,0,16,0"/>
                    <TextBlock Text="Threshold (min)" Foreground="{DynamicResource WhiteBrush}" VerticalAlignment="Center" Margin="0,0,6,0"/>
                    <TextBox Text="{Binding ThresholdMinutes, UpdateSourceTrigger=PropertyChanged}" Width="48" VerticalAlignment="Center"/>
                </StackPanel>

                <!-- Account rows -->
                <Border Grid.Row="2" Background="{DynamicResource RowBgBrush}"
                        BorderBrush="{DynamicResource DividerBrush}" BorderThickness="1"
                        CornerRadius="6" Padding="4">
                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                        <ItemsControl ItemsSource="{Binding Accounts}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Grid Margin="6,4">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <StackPanel Grid.Column="0">
                                            <TextBlock Text="{Binding DisplayName}" Foreground="{DynamicResource WhiteBrush}" FontWeight="SemiBold"/>
                                            <StackPanel Orientation="Horizontal">
                                                <TextBlock Text="{Binding IdleText}" Foreground="{DynamicResource WhiteBrush}" Opacity="0.7" FontSize="11"/>
                                                <TextBlock Text="{Binding LastKeptText}" Foreground="{DynamicResource MutedTextBrush}"
                                                           FontSize="11" Margin="8,0,0,0"/>
                                            </StackPanel>
                                        </StackPanel>
                                        <CheckBox Grid.Column="1" IsChecked="{Binding Enabled}" VerticalAlignment="Center"/>
                                    </Grid>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                </Border>

                <!-- Notifications -->
                <Expander Grid.Row="3" Header="Notifications" Margin="0,12,0,0">
                    <StackPanel Margin="8">
                        <TextBlock Text="Lead time before a grab (seconds)" Foreground="{DynamicResource WhiteBrush}" Opacity="0.7" FontSize="11"/>
                        <Slider Minimum="0" Maximum="10" TickFrequency="1" IsSnapToTickEnabled="True"
                                Value="{Binding LeadSeconds}"/>

                        <TextBlock Text="Pill visibility" Foreground="{DynamicResource WhiteBrush}" Opacity="0.7" FontSize="11" Margin="0,10,0,0"/>
                        <ComboBox ItemsSource="{Binding Source={StaticResource PillModeValues}}"
                                  SelectedItem="{Binding PillModeSetting}"/>

                        <TextBlock Text="Pill corner" Foreground="{DynamicResource WhiteBrush}" Opacity="0.7" FontSize="11" Margin="0,10,0,0"/>
                        <ComboBox ItemsSource="{Binding Source={StaticResource PillCornerValues}}"
                                  SelectedItem="{Binding PillCornerSetting}"/>

                        <CheckBox Content="Play a sound on grab"
                                  IsChecked="{Binding SoundOnGrab}" Margin="0,10,0,0"/>

                        <TextBlock Text="F8 skips the next grab" Foreground="{DynamicResource MutedTextBrush}"
                                   FontSize="11" Margin="0,10,0,0"/>
                    </StackPanel>
                </Expander>

                <!-- Footer -->
                <Border Grid.Row="4" Margin="0,12,0,0" Padding="0,8,0,0"
                        BorderBrush="{DynamicResource DividerBrush}" BorderThickness="0,1,0,0">
                    <TextBlock Text="{Binding FooterText}"
                               FontFamily="{StaticResource MonoFont}"
                               Foreground="{DynamicResource MutedTextBrush}"
                               FontSize="10"/>
                </Border>
            </Grid>
        </Grid>
    </Border>
</Window>
