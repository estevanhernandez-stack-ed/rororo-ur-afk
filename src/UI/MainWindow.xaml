<Window x:Class="Labs626.UrAfk.UI.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:sys="clr-namespace:System;assembly=mscorlib"
        xmlns:core="clr-namespace:Labs626.UrAfk.Core"
        Title="RoRoRo Ur AFK" Width="420" Height="620"
        MinWidth="380" MinHeight="480"
        Background="{DynamicResource BgBrush}"
        FontFamily="Segoe UI">
    <Window.Resources>
        <ObjectDataProvider x:Key="PillModeValues" MethodName="GetValues" ObjectType="{x:Type sys:Enum}">
            <ObjectDataProvider.MethodParameters>
                <x:Type TypeName="core:PillMode"/>
            </ObjectDataProvider.MethodParameters>
        </ObjectDataProvider>
        <ObjectDataProvider x:Key="PillCornerValues" MethodName="GetValues" ObjectType="{x:Type sys:Enum}">
            <ObjectDataProvider.MethodParameters>
                <x:Type TypeName="core:PillCorner"/>
            </ObjectDataProvider.MethodParameters>
        </ObjectDataProvider>
        <!-- Status dot — themed per state via DynamicResource so it follows host
             theme switches live (replaces the frozen-hex PillBrushConverter). -->
        <Style x:Key="PillDotStyle" TargetType="Border">
            <Setter Property="Background" Value="{DynamicResource MutedTextBrush}"/>
            <Style.Triggers>
                <DataTrigger Binding="{Binding Pill.Kind}" Value="Watching">
                    <Setter Property="Background" Value="{DynamicResource CyanBrush}"/>
                </DataTrigger>
                <DataTrigger Binding="{Binding Pill.Kind}" Value="PreGrab">
                    <Setter Property="Background" Value="{DynamicResource MagentaBrush}"/>
                </DataTrigger>
                <DataTrigger Binding="{Binding Pill.Kind}" Value="Grabbing">
                    <Setter Property="Background" Value="{DynamicResource MagentaBrush}"/>
                </DataTrigger>
                <DataTrigger Binding="{Binding Pill.Kind}" Value="ConsentRevoked">
                    <Setter Property="Background" Value="{DynamicResource AmberBrush}"/>
                </DataTrigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header: title + pill (colored dot + status text) -->
        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,12">
            <TextBlock Text="RoRoRo Ur AFK" FontSize="18" FontWeight="Bold"
                       Foreground="{DynamicResource WhiteBrush}" VerticalAlignment="Center"/>
            <Border Width="10" Height="10" CornerRadius="5" Margin="14,0,6,0" VerticalAlignment="Center"
                    Style="{StaticResource PillDotStyle}"/>
            <TextBlock Text="{Binding Pill.Text}" Foreground="{DynamicResource WhiteBrush}" Opacity="0.8"
                       VerticalAlignment="Center" TextTrimming="CharacterEllipsis"/>
        </StackPanel>

        <!-- Master toggle + threshold -->
        <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,0,0,12">
            <ToggleButton Content="Keep-active" IsChecked="{Binding MasterEnabled}" Padding="12,4" Margin="0,0,16,0"/>
            <TextBlock Text="Threshold (min)" Foreground="{DynamicResource WhiteBrush}" VerticalAlignment="Center" Margin="0,0,6,0"/>
            <TextBox Text="{Binding ThresholdMinutes, UpdateSourceTrigger=PropertyChanged}" Width="48"/>
        </StackPanel>

        <!-- Account rows -->
        <Border Grid.Row="2" BorderBrush="{DynamicResource DividerBrush}" BorderThickness="1"
                CornerRadius="4" Padding="4">
            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <ItemsControl ItemsSource="{Binding Accounts}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Grid Margin="4">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0">
                                    <TextBlock Text="{Binding DisplayName}" Foreground="{DynamicResource WhiteBrush}" FontWeight="SemiBold"/>
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="{Binding IdleText}" Foreground="{DynamicResource WhiteBrush}" Opacity="0.7" FontSize="11"/>
                                        <TextBlock Text="{Binding LastKeptText}" Foreground="{DynamicResource MutedTextBrush}"
                                                   FontSize="11" Margin="8,0,0,0"/>
                                    </StackPanel>
                                </StackPanel>
                                <CheckBox Grid.Column="1" IsChecked="{Binding Enabled}" VerticalAlignment="Center"/>
                            </Grid>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>
        </Border>

        <!-- Notifications -->
        <Expander Grid.Row="3" Header="Notifications" Foreground="{DynamicResource WhiteBrush}" Margin="0,12,0,0">
            <StackPanel Margin="8">
                <TextBlock Text="Lead time before a grab (seconds)" Foreground="{DynamicResource WhiteBrush}" Opacity="0.7" FontSize="11"/>
                <Slider Minimum="0" Maximum="10" TickFrequency="1" IsSnapToTickEnabled="True"
                        Value="{Binding LeadSeconds}"/>

                <TextBlock Text="Pill visibility" Foreground="{DynamicResource WhiteBrush}" Opacity="0.7" FontSize="11" Margin="0,10,0,0"/>
                <ComboBox ItemsSource="{Binding Source={StaticResource PillModeValues}}"
                          SelectedItem="{Binding PillModeSetting}"/>

                <TextBlock Text="Pill corner" Foreground="{DynamicResource WhiteBrush}" Opacity="0.7" FontSize="11" Margin="0,10,0,0"/>
                <ComboBox ItemsSource="{Binding Source={StaticResource PillCornerValues}}"
                          SelectedItem="{Binding PillCornerSetting}"/>

                <CheckBox Content="Play a sound on grab" Foreground="{DynamicResource WhiteBrush}"
                          IsChecked="{Binding SoundOnGrab}" Margin="0,10,0,0"/>

                <TextBlock Text="F8 skips the next grab" Foreground="{DynamicResource MutedTextBrush}"
                           FontSize="11" Margin="0,10,0,0"/>
            </StackPanel>
        </Expander>

        <!-- Footer -->
        <TextBlock Grid.Row="4" Text="{Binding FooterText}" Foreground="{DynamicResource MutedTextBrush}"
                    FontSize="11" Margin="0,12,0,0"/>
    </Grid>
</Window>
